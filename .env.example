# OpenClaw (Sapphire fork) - .env.example for Free LLMs + MCP
# Copy to .env and fill your keys!
# gitignore protects .env

# === Free LLM Providers (No paid required) ===
GITHUB_PERSONAL_ACCESS_TOKEN=gho_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Get from: https://github.com/settings/tokens > Fine-grained > repo+gist scopes

GOOGLE_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Get from: https://aistudio.google.com/app/apikey (free 15 RPM / 1M tokens/day)

HUGGINGFACE_TOKEN=hf_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Get from: https://huggingface.co/settings/tokens (free tier)

# === Local Models (No API key) ===
OLLAMA_BASE_URL=http://localhost:11434/v1
LM_STUDIO_BASE_URL=http://100.113.135.14:1234/v1  # Your IP

# === MCP Server ===
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=5000
MCP_ENABLE_ALL=true
# Or specific: MCP_ENABLE_CODE=true, MCP_ENABLE_NETWORK=true etc.

# === Optional Paid/Advanced ===
# ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# AWS_BEDROCK_ACCESS_KEY=XXXXXXXXXXXXXXXXXXXX
# AWS_BEDROCK_SECRET_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
