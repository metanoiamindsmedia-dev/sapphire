# Sapphire AI Assistant - Environment Configuration
# Copy to .env and fill in your API keys and configuration values
# This file documents best practices for Sapphire configuration with MCP Docker Server integration

# ============================================================================
# LLM API KEYS - At least one must be configured for Sapphire to function
# ============================================================================

# Anthropic Claude - For claudia, claude-sonnet, claude-opus models
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI - For GPT-4o, GPT-4-turbo models
OPENAI_API_KEY=sk-...

# Google Gemini - For Gemini models with extended thinking
GOOGLE_API_KEY=...

# Fireworks AI - For fine-tuned and open models
FIREWORKS_API_KEY=...

# XAI Grok - For Grok models
XAI_API_KEY=...

# Featherless AI - For DeepSeek and other models
FEATHERLESS_API_KEY=...

# ============================================================================
# SPEECH & TTS SERVICES
# ============================================================================

# ElevenLabs - For high-quality text-to-speech (requires API key + voice ID setup)
ELEVENLABS_API_KEY=...

# Fireworks STT - For speech-to-text service
FIREWORKS_STT_API_KEY=${FIREWORKS_API_KEY}

# ============================================================================
# SAPPHIRE ROUTING & MULTI-TENANT (Optional)
# ============================================================================

# Sapphire Router - For routing requests to specific Sapphire instances
SAPPHIRE_ROUTER_URL=
SAPPHIRE_ROUTER_TENANT_ID=

# ============================================================================
# MCP DOCKER SERVER INTEGRATION
# This section configures Sapphire to access MCP tools via Docker container
# ============================================================================

# MCP Server Connection
# Host: docker-host or localhost (depends on your setup)
# Port: Typically 5000 or custom port where your MCP server is listening
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=5000

# Available MCP Tool Categories (enable what you need)
# When enabled, these tools become available to agents and personas
MCP_ENABLE_GITHUB=true
MCP_ENABLE_AZURE=true
MCP_ENABLE_AWS=true
MCP_ENABLE_FILESYSTEM=true
MCP_ENABLE_FETCH=true
MCP_ENABLE_MEMORY=true
MCP_ENABLE_SEQUENTIALTHINKING=true
MCP_ENABLE_PLAYWRIGHT=true
MCP_ENABLE_GIT=true
MCP_ENABLE_NODE_SANDBOX=true
MCP_ENABLE_HUGGINGFACE=true
MCP_ENABLE_DESKTOP_COMMANDER=true

# GitHub Enterprise Integration (optional)
# GITHUB_PERSONAL_ACCESS_TOKEN is used by MCP GitHub tools
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...

# Azure CLI Authentication (optional)
# Used by MCP Azure tools for subscription/resource access
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# AWS Credentials (optional)
# Used by MCP AWS tools
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Hugging Face Integration (optional)
# For accessing Hugging Face models and datasets
HUGGINGFACE_TOKEN=hf_...

# ============================================================================
# SAPPHIRE-SPECIFIC SETTINGS
# (These can also be configured via Web UI -> Settings)
# ============================================================================

# Default Persona (by name from core/personas/personas.json)
DEFAULT_PERSONA=sapphire

# Default User Name
DEFAULT_USERNAME=Human Protagonist

# Default Toolset (none, web, advanced, etc.)
DEFAULT_TOOLSET=advanced

# Web UI Settings
WEB_UI_HOST=0.0.0.0
WEB_UI_PORT=8073

# Privacy Mode
# When enabled, blocks all outbound connections except to whitelisted services
PRIVACY_MODE=false

# Create backups automatically
BACKUPS_ENABLED=true

# ============================================================================
# LOGGING & DEBUG
# ============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Set to DEBUG for troubleshooting MCP integration issues
LOG_LEVEL=INFO

# Debug tool calling - verbose output when agents/personas invoke tools
DEBUG_TOOL_CALLING=false

# ============================================================================
# ADVANCED - Sapphire Router Configuration
# (Only needed if running in managed/multi-tenant mode)
# ============================================================================

# Router Base URL
SAPPHIRE_ROUTER_URL=https://router.sapphire.local

# Your tenant/instance ID
SAPPHIRE_ROUTER_TENANT_ID=tenant-12345

# ============================================================================
# SETUP WIZARD
# (Normally set via Web UI, but can be pre-configured here)
# ============================================================================

# Configuration wizard step tracking (0-4)
SETUP_WIZARD_STEP=4
